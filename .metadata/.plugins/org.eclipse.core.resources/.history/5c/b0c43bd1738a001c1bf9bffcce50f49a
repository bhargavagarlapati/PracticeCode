package Learning;

import java.util.HashMap;
import java.util.HashSet;
import java.util.Map.Entry;

public class Practice {

	public static void main(String[] args) {

		Integer I = 1331;

		StringBuilder s = new StringBuilder(I.toString());

		if (s.reverse().toString().equals(I.toString()))

		{
			System.out.println("Palindrome");
		}

		else {
			System.out.println("Not a Palindrome");
		}

		Practice.m1();
		
		
	}

	public static void m1() {
		int a[] = { 2, 2, 2, 3, 3, 4, 4, 6 };

		HashMap<Integer, Integer> h = new HashMap<Integer, Integer>();

		HashSet<Integer> hs = new HashSet<Integer>();

		for (int i = 0; i < a.length; i++) {

			if (!h.containsKey(i))

			{

				int k = a[i];
				int count = 0;

				for (int j = 0; j < a.length; j++)

				{
					if (a[j] == k)

						count++;

				}

				h.put(k, count);
			}

		}

		for (Entry<Integer, Integer> e : h.entrySet()) {

			if ((Integer) e.getValue() == 1) {
				hs.add((Integer) e.getKey());
			}

		}

		System.out.println(hs);

	}

	public boolean palindromechecker(String s) {
		for (int i = 0; i < s.length(); i++) {
			
			if(!(s.charAt(i) == s.charAt(s.length()-i-1)))
			{
				return false;				
			}						

		}
		return true;
		
	}
}
